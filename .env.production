# # ========================================
# # PRODUCTION ENVIRONMENT CONFIGURATION
# # ========================================
# # ⚠️ IMPORTANT: Thay đổi tất cả giá trị mặc định
# # ⚠️ Store trong secrets manager (AWS Secrets, Vault, etc)

# # ==========================================
# # Application Settings
# # ==========================================
# PROJECT_NAME=Mini SOC Portal
# ENV=production
# DEBUG=false
# MOCK_OPENSEARCH=false

# # ==========================================
# # API Settings
# # ==========================================
# API_V1_STR=/api/v1

# # ==========================================
# # Security - CHANGE THESE!
# # ==========================================
# # Generate new SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_SECURE_RANDOM_KEY
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7
# DEFAULT_ADMIN_PASSWORD=CHANGE_ME_SET_SECURE_PASSWORD

# # ==========================================
# # CORS - Restrict to specific domains
# # ==========================================
# BACKEND_CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# # ==========================================
# # PostgreSQL Database
# # ==========================================
# POSTGRES_SERVER=db
# POSTGRES_USER=soc_admin
# POSTGRES_PASSWORD=CHANGE_ME_SECURE_DB_PASSWORD
# POSTGRES_DB=mini_soc_production
# POSTGRES_PORT=5432

# # ==========================================
# # Redis Cache
# # ==========================================
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=CHANGE_ME_SECURE_REDIS_PASSWORD

# # ==========================================
# # OpenSearch (SIEM Data Storage)
# # ==========================================
# OPENSEARCH_HOSTS=["https://opensearch1:9200","https://opensearch2:9200"]
# OPENSEARCH_USER=opensearch_admin
# OPENSEARCH_PASSWORD=CHANGE_ME_SECURE_OPENSEARCH_PASSWORD
# OPENSEARCH_VERIFY_CERTS=true
# OPENSEARCH_SSL_SHOW_WARN=false

# # ==========================================
# # Rate Limiting
# # ==========================================
# RATE_LIMIT_PER_MINUTE=100

# # ==========================================
# # Frontend URLs (for API calls)
# # ==========================================
# VITE_API_URL=https://yourdomain.com/api/v1
# VITE_WS_URL=wss://yourdomain.com

# # ==========================================
# # Logging & Monitoring
# # ==========================================
# LOG_LEVEL=INFO
# ENABLE_SENTRY=true
# SENTRY_DSN=https://key@sentry.example.com/project-id

# # ==========================================
# # Email (for alerts, notifications)
# # ==========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASSWORD=CHANGE_ME_EMAIL_PASSWORD
# ADMIN_EMAIL=admin@yourdomain.com
